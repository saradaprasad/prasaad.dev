---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Not found | Prasad" description="Page not found.">
  <main class="max-w-2xl mx-auto px-6 py-24 text-center">
    <h1 class="text-xl font-semibold">404</h1>
    <p class="mt-2 text-[var(--muted)] text-sm">Page not found.</p>
    <a
      href="/"
      class="mt-6 inline-block text-sm text-[var(--muted)] hover:text-[var(--fg)] underline underline-offset-2"
    >
      ← Home
    </a>
  </main>
</Layout>
