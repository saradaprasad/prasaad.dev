---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
const posts = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Blog | Prasad" description="Technical deep dives and engineering notes.">
  <main class="max-w-[42rem] mx-auto px-6 py-14 sm:py-20">
    <header class="mb-10">
      <h1 class="text-2xl font-semibold tracking-tight">Blog</h1>
    </header>
    <ul class="space-y-10 list-none p-0 m-0">
      {
        posts.map((entry) => (
          <li>
            <a
              href={`/blog/${entry.id}`}
              class="group block no-underline"
            >
              <h2 class="text-lg font-medium text-[var(--link)] group-hover:text-[var(--linkHover)] transition-colors">
                {entry.data.title}
              </h2>
              <p class="mt-1 text-sm text-[var(--muted)] line-clamp-2">
                {entry.data.description}
              </p>
              <time
                class="mt-2 block text-xs text-[var(--subtle)]"
                datetime={entry.data.pubDate.toISOString()}
              >
                {entry.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
